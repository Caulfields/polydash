{
  "version": 2,
  "functions": {
    "api/**/*.js": { "runtime": "nodejs20.x" }
  },
  "routes": [
    { "src": "/api/gamma/(.*)", "dest": "/api/gamma/$1" },
    { "src": "/api/clob/(.*)",  "dest": "/api/clob/$1"  },
    { "src": "/api/data/(.*)",  "dest": "/api/data/$1"  },
    { "src": "/api/metar",      "dest": "/api/metar"    },
    { "src": "/api/me",         "dest": "/api/me"       },
    { "src": "/(.*)",           "dest": "/index.html"   }
  ]
}
